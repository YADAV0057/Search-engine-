# SAVE AS: engine/.env.example

# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase
# for every Edge Function in this project — you do NOT need to set these
# manually as function secrets. Listed here only so the dependency is
# visible when reading this file.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides — all adapters work with zero config using the
# public API defaults baked into the adapter files.
# JIKAN_URL=https://api.jikan.moe/v4
# KITSU_URL=https://kitsu.io/api/edge
# MANGADEX_URL=https://api.mangadex.org
# MANGADEX_COVER_URL=https://uploads.mangadex.org/covers

# Required for harvest-lexicons only (not used by search). Shared secret
# checked against the x-harvest-secret header — this function does real
# write work and burns AniList's shared 90 req/min quota, so it must not
# be left open the way search's CORS-allowlisted endpoint is.
# HARVEST_SECRET=
